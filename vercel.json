{
  "version": 2,
  "builds": [
    {
      "src": "dist/src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/src/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/cron/login-history-report",
      "schedule": "30 1 * * *"
    }
  ]
}
