NODE_ENV=development
PORT=3000
LOG_LEVEL=info                                # debug | info | warn | error

DATABASE_URL="postgresql://user:password@localhost:5432/crelyzor"
BASE_URL=http://localhost:3000                # API base URL (used internally for link generation)
BASE_URL_SHORTNER=http://localhost:3000
PUBLIC_URL=                                   # Public site URL — used in QR codes on cards (e.g. http://localhost:5174 locally, https://crelyzor.app in prod) REQUIRED
FRONTEND_URL=http://localhost:5173            # Dashboard URL — used in email links
HARD_DELETE_ENABLED=false
AUTO_START_CRON=false

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Auth
JWT_ACCESS_SECRET=""                          # generate with: openssl rand -hex 32
JWT_REFRESH_SECRET=""                         # generate with: openssl rand -hex 32

# Admin Portal
ADMIN_JWT_SECRET=""                           # generate with: openssl rand -hex 32
ADMIN_PORTAL_URL="http://localhost:5175"      # used to build invite links in emails

# First-time setup only — run once: docker compose exec backend pnpm admin:seed
# After the first admin is created, delete these three vars
ADMIN_SEED_EMAIL=""
ADMIN_SEED_PASSWORD=""
ADMIN_SEED_NAME=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_LOGIN_REDIRECT_URI=""

# AI & Transcription
GEMINI_API_KEY=""                             # Gemini 2.5 Flash — used for AI summaries and Ask AI
DEEPGRAM_API_KEY=""                           # Deepgram Nova-3 — used for transcription

# Storage (Google Cloud Storage)
# Auth is handled via gcloud ADC — no key file needed.
# Local: run `gcloud auth application-default login` (see SETUP.md)
# Production: attach service account to GCE VM at creation time
GCS_PROJECT_ID=""                             # GCP project ID
GCS_BUCKET_NAME=""                            # e.g. crelyzor-dev / crelyzor-prod

# Redis — local container in Docker Compose, external URL for standalone dev
REDIS_URL="redis://redis:6379"

# Recall.ai (optional — enables auto-record for online meetings)
RECALL_API_KEY=""
RECALL_WEBHOOK_SECRET=""
RECALL_BASE_URL=""                            # Regional endpoint, e.g. https://ap-northeast-1.recall.ai/api/v1 (defaults to US if unset)

# Email — Resend (optional — emails silently skipped if absent)
RESEND_API_KEY=""                             # Get from resend.com
RESEND_FROM_EMAIL="Crelyzor <notifications@crelyzor.com>"  # Must match a verified Resend domain

# Google Calendar push webhooks
GOOGLE_WEBHOOK_BASE_URL=""                    # Public HTTPS URL Google can reach, e.g. https://api.crelyzor.com
GCAL_WEBHOOK_SECRET=""                        # Random secret sent as X-Goog-Channel-Token for request verification

# Payment gateway — Razorpay (DEFERRED — account blocked. Uncomment when live)
# RAZORPAY_KEY_ID=""
# RAZORPAY_KEY_SECRET=""
# RAZORPAY_WEBHOOK_SECRET=""
# RAZORPAY_PRO_PLAN_ID=""                    # Razorpay Plan ID for the Pro subscription
