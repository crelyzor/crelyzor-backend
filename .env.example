PORT=3000
DATABASE_URL="postgresql://user:password@localhost:5432/crelyzor"
BASE_URL_SHORTNER=http://localhost:3000
HARD_DELETE_ENABLED=false
AUTO_START_CRON=false

# Auth
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_LOGIN_REDIRECT_URI=""

# AI & Transcription
OPENAI_API_KEY=""
DEEPGRAM_API_KEY=""

# Storage (Google Cloud Storage)
GCS_BUCKET_NAME=""

# Redis
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
REDIS_URL=""

# Recall.ai (optional — enables auto-record for online meetings)
RECALL_API_KEY=""
RECALL_WEBHOOK_SECRET=""
RECALL_BASE_URL=""                    # Regional endpoint, e.g. https://ap-northeast-1.recall.ai/api/v1 (defaults to US if unset)

# Email — Resend (optional — allows sending transactional emails)
RESEND_API_KEY=""                     # Get from resend.com — emails silently skipped if absent
RESEND_FROM_EMAIL="Crelyzor <notifications@crelyzor.com>"   # Must match a verified Resend domain

# Google Calendar push webhooks (Phase 4.3 — two-way real-time sync)
GOOGLE_WEBHOOK_BASE_URL=""            # Public HTTPS URL Google can reach, e.g. https://api.crelyzor.com
GCAL_WEBHOOK_SECRET=""                # Random secret sent as X-Goog-Channel-Token for request verification

# Payment gateway — Razorpay (DEFERRED — account blocked. Uncomment when live)
# RAZORPAY_KEY_ID=""
# RAZORPAY_KEY_SECRET=""
# RAZORPAY_WEBHOOK_SECRET=""
# RAZORPAY_PRO_PLAN_ID=""            # Razorpay Plan ID for the Pro subscription
