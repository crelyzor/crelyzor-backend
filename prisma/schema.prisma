generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================
// CORE USER & AUTHENTICATION
// ================================

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  emailVerified   Boolean   @default(false)
  name            String
  avatarUrl       String?
  countryCode     String?
  phoneNumber     String?
  lastLoginAt     DateTime?
  isActive        Boolean   @default(true)
  activeSessionId String?
  timezone        String    @default("UTC")

  // Soft delete fields
  deletedAt    DateTime?
  deletedById  String?   @db.Uuid
  deletedOrgId String?   @db.Uuid

  // Location
  country String?
  state   String?
  city    String?

  // Meeting preference
  meetingPreference ProviderEnum?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  loginHistory           LoginHistory[]
  oauthAccounts          OAuthAccount[]
  organizationMembers    OrganizationMember[]
  refreshTokens          RefreshToken[]
  sessions               Session[]
  calendarEvents         GoogleCalendarEvent[]
  googleCalendarSyncLogs GoogleCalendarSyncLog[]
  notifications          Notification[]
}

model Session {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  deviceInfo     String?
  ipAddress      String?
  createdAt      DateTime @default(now())
  expiredAt      DateTime
  lastAccessedAt DateTime
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginHistory {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @db.Uuid
  ipAddress     String
  deviceInfo    String
  loginTime     DateTime      @default(now())
  success       Boolean
  failureReason String?
  loginMethod   LoginMethod   @default(OAUTH)
  provider      ProviderEnum?
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loginTime])
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  token      String
  revoked    Boolean  @default(false)
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  deviceInfo String
  ipAddress  String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthAccount {
  id             String                  @id @default(uuid()) @db.Uuid
  provider       ProviderEnum
  providerId     String
  accessToken    String
  refreshToken   String
  expiry         Int
  scopes         String[]
  createdAt      DateTime                @default(now())
  userId         String                  @db.Uuid
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendarEvents GoogleCalendarEvent[]
  syncLogs       GoogleCalendarSyncLog[]

  @@unique([provider, providerId])
}

model OrgInvite {
  id           String       @id @default(uuid()) @db.Uuid
  orgId        String       @db.Uuid
  invitedEmail String
  invitedRole  UserRoleEnum
  invitedById  String       @db.Uuid  // who sent the invite
  token        String       @unique
  expiresAt    DateTime
  acceptedAt   DateTime?              // null = pending, set = accepted
  createdAt    DateTime     @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, invitedEmail])
  @@index([token])
  @@index([orgId])
}

// ================================
// ORGANIZATION & MEMBERSHIP
// ================================

model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Organization details (JSON for flexibility)
  organizationDetails Json

  // Email sender configuration for notifications (Brevo)
  brevoApiKey String?
  senderEmail String?
  senderName  String?

  // Organization branding
  orgLogoUrl String?
  brandColor String?

  // Personal workspace flag (true = personal workspace, false = team org)
  isPersonal Boolean @default(false)

  // Default meeting provider preference
  defaultMeetingProvider ProviderEnum?

  // Relations
  members              OrganizationMember[]
  roles                Role[]
  invites              OrgInvite[]
  notificationSettings OrgNotificationSettings?
  notificationPreferences NotificationPreference[]
  notificationLogs     NotificationLog[]

  // Calendar & Meeting Management
  meetings     Meeting[]
}

model OrganizationMember {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @db.Uuid
  userId      String   @db.Uuid
  roleId      String?  @db.Uuid
  accessLevel String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [orgId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Roles
  userRoles    UserRole[] @relation("UserRoleToOrgMember")

  // Calendar & Meeting Management
  meetingsCreated             Meeting[]                  @relation("MeetingCreatedBy")
  meetingParticipations       MeetingParticipant[]       @relation("MeetingParticipants")
  meetingStateChanges         MeetingStateHistory[]      @relation("MeetingStateChanges")
  rescheduleRequestsCreated   MeetingRescheduleRequest[] @relation("RescheduleRequestedBy")
  rescheduleRequestsResponded MeetingRescheduleRequest[] @relation("RescheduleRespondedBy")
  availability                MemberAvailability[]       @relation("MemberAvailability")
  customSlots                 MemberCustomSlot[]         @relation("MemberCustomSlots")
  blockedTimes                MemberBlockedTime[]        @relation("MemberBlockedTimes")

  // Public booking link
  shareToken             String?  @unique
  isPublicBookingEnabled Boolean  @default(false)

  @@unique([orgId, userId])
}

// ================================
// ROLES & PERMISSIONS
// ================================

model Role {
  id             String        @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  isSystemRole   Boolean       @default(false)
  systemRoleType UserRoleEnum?
  orgId          String        @db.Uuid
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userRoles      UserRole[]
  permissions    Permission[]  @relation("RoleToPermission")

  @@unique([orgId, name])
  @@index([orgId])
  @@index([systemRoleType])
}

model UserRole {
  id          String             @id @default(uuid()) @db.Uuid
  orgMemberId String             @db.Uuid
  roleId      String             @db.Uuid
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  orgMember   OrganizationMember @relation("UserRoleToOrgMember", fields: [orgMemberId], references: [id], onDelete: Cascade)
  role        Role               @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, orgMemberId])
  @@index([orgMemberId])
  @@index([roleId])
}

model Permission {
  id       String  @id @default(uuid()) @db.Uuid
  name     String  @unique
  module   String  @default("Miscellaneous")
  isActive Boolean @default(true)
  roles    Role[]  @relation("RoleToPermission")
}

// ================================
// GOOGLE CALENDAR INTEGRATION
// ================================

model GoogleCalendarEvent {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  oauthAccountId   String   @db.Uuid
  googleEventId    String
  summary          String?
  description      String?
  location         String?
  startTime        DateTime
  endTime          DateTime
  status           String?
  attendees        Json?
  isAllDay         Boolean  @default(false)
  recurring        Boolean  @default(false)
  recurringEventId String?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastSyncedAt     DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  oauthAccount OAuthAccount @relation(fields: [oauthAccountId], references: [id], onDelete: Cascade)

  @@unique([oauthAccountId, googleEventId])
  @@index([userId])
  @@index([startTime])
}

model GoogleCalendarSyncLog {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  oauthAccountId    String   @db.Uuid
  lastSyncTime      DateTime @default(now())
  nextSyncToken     String?
  fullSyncCompleted Boolean  @default(false)
  status            String   @default("PENDING")
  errorMessage      String?
  eventsSynced      Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  oauthAccount OAuthAccount @relation(fields: [oauthAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, oauthAccountId])
  @@index([oauthAccountId, lastSyncTime])
}

// ================================
// CALENDAR & MEETING MANAGEMENT
// ================================

model Meeting {
  id            String        @id @default(uuid()) @db.Uuid
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  timezone      String        @default("UTC")
  mode          MeetingMode
  status        MeetingStatus @default(PENDING_ACCEPTANCE)
  location      String?       // For in-person meetings
  meetingLink   String?       // Zoom/GMeet URL
  meetingProvider ProviderEnum? // Which provider generated the link
  videoMeetingId  String?       // External meeting ID (Zoom meeting ID, Google Meet ID)
  googleEventId String?
  recordingLink String?
  notes         String?

  // Guest booking info (for public link requests)
  guestEmail   String?
  guestName    String?
  guestMessage String?

  // Tracking
  createdById    String        @db.Uuid
  createdByRole  UserRoleEnum?
  organizationId String        @db.Uuid
  isDeleted      Boolean      @default(false)
  deletedAt      DateTime?
  deletedBy      String?      @db.Uuid

  // Transcription processing status
  transcriptionStatus TranscriptionStatus @default(NONE)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  createdByMember    OrganizationMember         @relation("MeetingCreatedBy", fields: [createdById], references: [id])
  organization       Organization               @relation(fields: [organizationId], references: [id])
  participants       MeetingParticipant[]
  guests             MeetingGuest[]
  stateHistory       MeetingStateHistory[]
  rescheduleRequests MeetingRescheduleRequest[]

  // Smart Meeting Assistant relations
  recording   MeetingRecording?
  speakers    MeetingSpeaker[]
  actionItems MeetingActionItem[]
  meetingNotes MeetingNote[]
  aiSummary   MeetingAISummary?

  @@index([organizationId, status])
  @@index([createdById])
  @@index([startTime])
  @@index([googleEventId])
  @@index([status, isDeleted])
  @@index([guestEmail])
  @@index([transcriptionStatus])
}

model MeetingParticipant {
  id              String          @id @default(uuid()) @db.Uuid
  meetingId       String          @db.Uuid
  orgMemberId     String          @db.Uuid
  participantType ParticipantType
  responseStatus  ResponseStatus  @default(PENDING)
  respondedAt     DateTime?
  joinedAt        DateTime?

  meeting   Meeting            @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  orgMember OrganizationMember @relation("MeetingParticipants", fields: [orgMemberId], references: [id])

  @@unique([meetingId, orgMemberId])
  @@index([orgMemberId])
  @@index([meetingId])
}

model MeetingGuest {
  id             String         @id @default(uuid()) @db.Uuid
  meetingId      String         @db.Uuid
  email          String
  name           String?
  responseStatus ResponseStatus @default(PENDING)
  respondedAt    DateTime?
  createdAt      DateTime       @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, email])
  @@index([meetingId])
  @@index([email])
}

model MeetingStateHistory {
  id          String         @id @default(uuid()) @db.Uuid
  meetingId   String         @db.Uuid
  fromStatus  MeetingStatus?
  toStatus    MeetingStatus
  changedById String         @db.Uuid
  reason      String?
  changedAt   DateTime       @default(now())

  meeting   Meeting            @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  changedBy OrganizationMember @relation("MeetingStateChanges", fields: [changedById], references: [id])

  @@index([meetingId])
  @@index([toStatus])
}

model MeetingRescheduleRequest {
  id                String         @id @default(uuid()) @db.Uuid
  meetingId         String         @db.Uuid
  requestedById     String         @db.Uuid
  proposedStartTime DateTime
  proposedEndTime   DateTime
  reason            String?
  status            ResponseStatus @default(PENDING)
  respondedById     String?        @db.Uuid
  respondedAt       DateTime?
  responseNotes     String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  meeting     Meeting             @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  requestedBy OrganizationMember  @relation("RescheduleRequestedBy", fields: [requestedById], references: [id])
  respondedBy OrganizationMember? @relation("RescheduleRespondedBy", fields: [respondedById], references: [id])

  @@index([meetingId])
  @@index([status])
}

// ================================
// AVAILABILITY MANAGEMENT
// ================================

model MemberAvailability {
  id          String    @id @default(uuid()) @db.Uuid
  orgMemberId String    @db.Uuid
  dayOfWeek   DayOfWeek
  startTime   String // "HH:MM"
  endTime     String // "HH:MM"
  timezone    String    @default("UTC")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  orgMember OrganizationMember @relation("MemberAvailability", fields: [orgMemberId], references: [id], onDelete: Cascade)

  @@unique([orgMemberId, dayOfWeek, startTime, endTime])
  @@index([orgMemberId, isActive])
}

model MemberCustomSlot {
  id          String   @id @default(uuid()) @db.Uuid
  orgMemberId String   @db.Uuid
  date        DateTime
  startTime   String // "HH:MM"
  endTime     String // "HH:MM"
  timezone    String   @default("UTC")
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orgMember OrganizationMember @relation("MemberCustomSlots", fields: [orgMemberId], references: [id], onDelete: Cascade)

  @@index([orgMemberId, date])
  @@index([orgMemberId, isActive])
}

model MemberBlockedTime {
  id             String         @id @default(uuid()) @db.Uuid
  orgMemberId    String         @db.Uuid
  startTime      DateTime
  endTime        DateTime
  reason         String?
  recurrenceRule RecurrenceRule @default(NONE)
  recurrenceEnd  DateTime?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  orgMember OrganizationMember @relation("MemberBlockedTimes", fields: [orgMemberId], references: [id], onDelete: Cascade)

  @@index([orgMemberId, startTime, endTime])
  @@index([orgMemberId, isActive])
}

// ================================
// TRANSCRIPTION & AI (Smart Meeting Assistant)
// ================================

model MeetingRecording {
  id        String  @id @default(uuid()) @db.Uuid
  meetingId String  @unique @db.Uuid
  
  gcsPath   String  // Path in Google Cloud Storage
  duration  Int     // Duration in seconds
  fileSize  Int     // File size in bytes
  fileName  String

  uploadedBy String   @db.Uuid
  uploadedAt DateTime @default(now())

  meeting    Meeting     @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  transcript MeetingTranscript?

  @@index([meetingId])
}

model MeetingTranscript {
  id          String  @id @default(uuid()) @db.Uuid
  recordingId String  @unique @db.Uuid

  fullText String   // Complete transcript text

  deepgramJobId String?   // Track Deepgram async job
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  recording MeetingRecording     @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  segments  TranscriptSegment[]

  @@index([recordingId])
}

model TranscriptSegment {
  id           String @id @default(uuid()) @db.Uuid
  transcriptId String @db.Uuid

  speaker   String  // "Speaker 1", "Speaker 2", etc.
  text      String
  startTime Float   // seconds
  endTime   Float   // seconds

  transcript MeetingTranscript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)

  @@index([transcriptId])
  @@index([speaker])
}

model MeetingSpeaker {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @db.Uuid

  speakerLabel String  // "Speaker 1", "Speaker 2", etc. (from Deepgram diarization)
  displayName  String? // User-provided name
  role         String? // Custom role (e.g., "consultant", "client")

  organizationId String  @db.Uuid
  orgMemberId    String? @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, speakerLabel])
  @@index([meetingId])
  @@index([organizationId])
}

model MeetingActionItem {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @db.Uuid

  title       String
  description String?
  owner       String @db.Uuid // userId
  category    ActionItemCategory

  suggestedStartDate DateTime?
  suggestedEndDate   DateTime?
  assignedTo         String?   @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([owner])
}

model MeetingNote {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @db.Uuid

  content   String
  author    String @db.Uuid // userId
  timestamp Float? // seconds into the meeting

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([author])
}

model MeetingAISummary {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @unique @db.Uuid

  summary    String
  keyPoints  String[]
  
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

// ================================
// NOTIFICATION SYSTEM
// ================================

model NotificationLog {
  id             String             @id @default(uuid()) @db.Uuid
  orgId          String?            @db.Uuid
  senderEmail    String
  recipientEmail String
  recipientRole  String
  event          String
  payload        Json
  status         NotificationLogStatus
  reason         String?
  vendorResponse Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([event])
  @@index([status])
  @@index([createdAt])
}

model OrgNotificationSettings {
  id    String @id @default(uuid()) @db.Uuid
  orgId String @unique @db.Uuid

  notificationsEnabled Boolean                     @default(true)
  disabledRoles        NotificationRecipientType[] @default([])
  emailEnabled         Boolean                     @default(true)
  inAppEnabled         Boolean                     @default(true)

  defaultSenderEmail String?
  defaultSenderName  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model NotificationPreference {
  id    String @id @default(uuid()) @db.Uuid
  orgId String @db.Uuid

  eventType     NotificationEventType
  recipientType NotificationRecipientType

  emailEnabled Boolean @default(true)
  inAppEnabled Boolean @default(true)

  isEnabled       Boolean @default(true)
  emailTemplateId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, eventType, recipientType])
  @@index([orgId])
  @@index([eventType])
  @@index([recipientType])
}

// In-App Notifications (user's notification inbox)
model Notification {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  orgId  String? @db.Uuid

  type    NotificationEventType
  title   String
  message String
  data    Json?   // Additional data (meetingId, etc.)
  
  isRead  Boolean @default(false)
  readAt  DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([orgId])
}

// ================================
// ENUMS
// ================================

enum LoginMethod {
  OAUTH
}

enum ProviderEnum {
  GOOGLE
  ZOOM
}

enum UserRoleEnum {
  OWNER
  ADMIN
  MEMBER
}

enum SyncStatus {
  SUCCESS
  FAILED
  PENDING
}

enum MeetingMode {
  ONLINE
  IN_PERSON
}

enum MeetingStatus {
  CREATED
  PENDING_ACCEPTANCE
  ACCEPTED
  DECLINED
  COMPLETED
  CANCELLED
  RESCHEDULING_REQUESTED
}

enum ParticipantType {
  ORGANIZER
  ATTENDEE
}

enum ResponseStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum RecurrenceRule {
  NONE
  WEEKLY
  MONTHLY
}

enum TranscriptionStatus {
  NONE        // No recording uploaded
  UPLOADED    // Recording uploaded to GCS
  PROCESSING  // Transcription in progress
  COMPLETED   // Transcription complete
  FAILED      // Transcription failed
}

enum ActionItemCategory {
  PARTICIPANT_TASK
  SHARED_TASK
  DOCUMENT_REQUIRED
  UPCOMING_EVENT
  OTHER
}

enum NotificationLogStatus {
  SENT
  FAILED
  SKIPPED
  BLOCKED
}

enum NotificationEventType {
  TESTING_MAIL
  MEETING_SCHEDULED
  MEETING_RESCHEDULED
  MEETING_CANCELLED
  MEETING_REMINDER
  NEW_TEAM_MEMBER
  TRANSCRIPTION_COMPLETE
  ACTION_ITEMS_GENERATED
}

enum NotificationChannel {
  EMAIL
  IN_APP
}

enum NotificationRecipientType {
  ADMIN
  MEMBER
  ALL
}
