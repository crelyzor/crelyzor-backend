generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================
// CORE USER & AUTHENTICATION
// ================================

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  username        String?   @unique
  emailVerified   Boolean   @default(false)
  name            String
  avatarUrl       String?
  countryCode     String?
  phoneNumber     String?
  lastLoginAt     DateTime?
  isActive        Boolean   @default(true)
  activeSessionId String?
  timezone        String    @default("UTC")

  // Soft delete fields
  deletedAt   DateTime?
  deletedById String?   @db.Uuid

  // Location
  country String?
  state   String?
  city    String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  loginHistory  LoginHistory[]
  oauthAccounts OAuthAccount[]
  refreshTokens RefreshToken[]
  sessions      Session[]

  // Digital Cards
  cards        Card[]
  cardContacts CardContact[]

  // Meetings (user-level)
  meetingsCreated       Meeting[]             @relation("MeetingCreatedBy")
  meetingParticipations MeetingParticipant[]
  meetingStateChanges   MeetingStateHistory[] @relation("MeetingStateChanges")
  meetingSpeakers       MeetingSpeaker[]
}

model Session {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  deviceInfo     String?
  ipAddress      String?
  createdAt      DateTime @default(now())
  expiredAt      DateTime
  lastAccessedAt DateTime
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginHistory {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @db.Uuid
  ipAddress     String
  deviceInfo    String
  loginTime     DateTime      @default(now())
  success       Boolean
  failureReason String?
  loginMethod   LoginMethod   @default(OAUTH)
  provider      ProviderEnum?
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loginTime])
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  token      String
  revoked    Boolean  @default(false)
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  deviceInfo String
  ipAddress  String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthAccount {
  id           String       @id @default(uuid()) @db.Uuid
  provider     ProviderEnum
  providerId   String
  accessToken  String
  refreshToken String
  expiry       Int
  scopes       String[]
  createdAt    DateTime     @default(now())
  userId       String       @db.Uuid
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
}

// ================================
// MEETING MANAGEMENT
// ================================

model Meeting {
  id          String        @id @default(uuid()) @db.Uuid
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  timezone    String        @default("UTC")
  status      MeetingStatus @default(CREATED)
  location    String?
  notes       String?

  // Tracking
  createdById String    @db.Uuid
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedBy   String?   @db.Uuid

  // Transcription processing status
  transcriptionStatus TranscriptionStatus @default(NONE)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  createdBy    User                 @relation("MeetingCreatedBy", fields: [createdById], references: [id])
  participants MeetingParticipant[]
  stateHistory MeetingStateHistory[]

  // Smart Meeting Assistant relations
  recording    MeetingRecording?
  speakers     MeetingSpeaker[]
  actionItems  MeetingActionItem[]
  meetingNotes MeetingNote[]
  aiSummary    MeetingAISummary?

  @@index([createdById])
  @@index([startTime])
  @@index([status, isDeleted])
  @@index([transcriptionStatus])
}

model MeetingParticipant {
  id              String          @id @default(uuid()) @db.Uuid
  meetingId       String          @db.Uuid
  userId          String          @db.Uuid
  participantType ParticipantType
  joinedAt        DateTime?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@index([userId])
  @@index([meetingId])
}

model MeetingStateHistory {
  id          String         @id @default(uuid()) @db.Uuid
  meetingId   String         @db.Uuid
  fromStatus  MeetingStatus?
  toStatus    MeetingStatus
  changedById String         @db.Uuid
  reason      String?
  changedAt   DateTime       @default(now())

  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  changedBy User    @relation("MeetingStateChanges", fields: [changedById], references: [id])

  @@index([meetingId])
  @@index([toStatus])
}

// ================================
// TRANSCRIPTION & AI (Smart Meeting Assistant)
// ================================

model MeetingRecording {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @unique @db.Uuid

  gcsPath  String // Path in Google Cloud Storage
  duration Int    // Duration in seconds
  fileSize Int    // File size in bytes
  fileName String

  uploadedBy String   @db.Uuid
  uploadedAt DateTime @default(now())

  meeting    Meeting           @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  transcript MeetingTranscript?

  @@index([meetingId])
}

model MeetingTranscript {
  id          String @id @default(uuid()) @db.Uuid
  recordingId String @unique @db.Uuid

  fullText String // Complete transcript text

  deepgramJobId String?   // Track Deepgram async job
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  recording MeetingRecording    @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  segments  TranscriptSegment[]

  @@index([recordingId])
}

model TranscriptSegment {
  id           String @id @default(uuid()) @db.Uuid
  transcriptId String @db.Uuid

  speaker   String // "Speaker 1", "Speaker 2", etc.
  text      String
  startTime Float  // seconds
  endTime   Float  // seconds

  transcript MeetingTranscript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)

  @@index([transcriptId])
  @@index([speaker])
}

model MeetingSpeaker {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @db.Uuid

  speakerLabel String  // "Speaker 1", "Speaker 2", etc. (from Deepgram diarization)
  displayName  String? // User-provided name
  role         String? // Custom role (e.g., "consultant", "client")

  userId String? @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@unique([meetingId, speakerLabel])
  @@index([meetingId])
  @@index([userId])
}

model MeetingActionItem {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @db.Uuid

  title       String
  description String?
  owner       String             @db.Uuid // userId
  category    ActionItemCategory

  suggestedStartDate DateTime?
  suggestedEndDate   DateTime?
  assignedTo         String?   @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([owner])
}

model MeetingNote {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @db.Uuid

  content   String
  author    String @db.Uuid // userId
  timestamp Float? // seconds into the meeting

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([author])
}

model MeetingAISummary {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @unique @db.Uuid

  summary   String
  keyPoints String[]

  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

// ================================
// DIGITAL CARDS
// ================================

model Card {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  // Card content
  slug        String  // "default", "work", "startup"
  displayName String  // name shown on card (can differ from user.name)
  title       String? // "Software Engineer @ Acme"
  bio         String?
  avatarUrl   String?
  coverUrl    String? // banner/cover image

  // Structured fields
  links         Json @default("[]")  // [{type, url, label, icon}]
  contactFields Json @default("{}")  // {phone, email, location, website}

  // Theme & customization
  theme Json @default("{}") // {primaryColor, backgroundColor, fontFamily, layout, darkMode}

  // Template system
  templateId      String  @default("executive") // "executive" | "classic-bold" | "minimal"
  showQr          Boolean @default(true)        // Show QR code on back face
  htmlContent     String? @db.Text              // Generated front-face HTML
  htmlBackContent String? @db.Text              // Generated back-face HTML

  // Card state
  isDefault Boolean @default(false) // shown at /username
  isActive  Boolean @default(true)  // can be paused

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts CardContact[]
  views    CardView[]

  @@unique([userId, slug])
  @@index([userId, isActive])
  @@index([userId, isDefault])
}

model CardContact {
  id     String @id @default(uuid()) @db.Uuid
  cardId String @db.Uuid
  userId String @db.Uuid // card owner

  // Contact info submitted by scanner
  name    String
  email   String?
  phone   String?
  company String?
  note    String?

  // Organization & tagging
  tags String[] @default([]) // e.g., ["TechConf 2026", "networking"]

  // Tracking
  scannedAt      DateTime @default(now())
  savedByScanner Boolean  @default(false) // did they also save the card?

  // Relations
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([userId, scannedAt])
  @@index([email])
}

model CardView {
  id     String @id @default(uuid()) @db.Uuid
  cardId String @db.Uuid

  // Analytics data
  ipHash    String?  // hashed IP for unique visitor tracking (privacy-friendly)
  userAgent String?
  referrer  String?
  country   String?
  city      String?

  // Link click tracking
  clickedLink String? // which link was clicked (null = just a view)

  viewedAt DateTime @default(now())

  // Relations
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, viewedAt])
  @@index([cardId, clickedLink])
}

// ================================
// ENUMS
// ================================

enum LoginMethod {
  OAUTH
}

enum ProviderEnum {
  GOOGLE
  ZOOM
}

enum MeetingStatus {
  CREATED
  COMPLETED
  CANCELLED
}

enum ParticipantType {
  ORGANIZER
  ATTENDEE
}

enum TranscriptionStatus {
  NONE        // No recording uploaded
  UPLOADED    // Recording uploaded to GCS
  PROCESSING  // Transcription in progress
  COMPLETED   // Transcription complete
  FAILED      // Transcription failed
}

enum ActionItemCategory {
  PARTICIPANT_TASK
  SHARED_TASK
  DOCUMENT_REQUIRED
  UPCOMING_EVENT
  OTHER
}
