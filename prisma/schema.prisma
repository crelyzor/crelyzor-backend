// ENUMS
// ================================

enum LoginMethod {
  OAUTH
}

enum ProviderEnum {
  GOOGLE
  ZOOM
}

enum MeetingStatus {
  CREATED
  COMPLETED
  CANCELLED
}

enum MeetingType {
  SCHEDULED // Future: calendar/online meetings
  RECORDED // In-person meeting with uploaded/live recording
  VOICE_NOTE // Quick personal audio capture
}

enum ParticipantType {
  ORGANIZER
  ATTENDEE
}

enum TranscriptionStatus {
  NONE // No recording uploaded
  UPLOADED // Recording uploaded to GCS
  PROCESSING // Transcription in progress
  COMPLETED // Transcription complete
  FAILED // Transcription failed
}

enum TaskSource {
  AI_EXTRACTED
  MANUAL
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum AIContentType {
  MEETING_REPORT
  TWEET
  BLOG_POST
  EMAIL
}

enum AttachmentType {
  FILE
  LINK
  PHOTO
}

enum LocationType {
  IN_PERSON
  ONLINE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  DECLINED
  CANCELLED
  RESCHEDULED
  NO_SHOW
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum NotificationType {
  BOOKING_RECEIVED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  MEETING_AI_COMPLETE
  TASK_DUE_SOON
  TASK_ASSIGNED
}

// ─── Notifications (Phase 4.9) ────────────────────────────────────────────────

model Notification {
  id         String           @id @default(uuid()) @db.Uuid
  userId     String           @db.Uuid
  type       NotificationType
  title      String
  body       String?
  entityType String? // "meeting" | "booking" | "task"
  entityId   String?          @db.Uuid
  isRead     Boolean          @default(false)
  readAt     DateTime?
  isDeleted  Boolean          @default(false)
  deletedAt  DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt(sort: Desc)]) // list query: WHERE userId=X ORDER BY createdAt DESC
  @@index([userId, isRead]) // unread count: WHERE userId=X AND isRead=false
}

// ─── Admin ────────────────────────────────────────────────────────────────────

model AdminUser {
  id           String        @id @default(uuid()) @db.Uuid
  email        String        @unique
  passwordHash String
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  invitesSent  AdminInvite[]
}

model AdminInvite {
  id          String    @id @default(uuid()) @db.Uuid
  email       String
  token       String    @unique
  invitedById String    @db.Uuid
  invitedBy   AdminUser @relation(fields: [invitedById], references: [id])
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([invitedById])
  @@index([email])
  @@index([expiresAt])
}
