generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================
// CORE USER & AUTHENTICATION
// ================================

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  username        String?   @unique
  emailVerified   Boolean   @default(false)
  name            String
  avatarUrl       String?
  countryCode     String?
  phoneNumber     String?
  lastLoginAt     DateTime?
  isActive        Boolean   @default(true)
  activeSessionId String?
  timezone        String    @default("UTC")

  // Soft delete fields
  deletedAt    DateTime?
  deletedById  String?   @db.Uuid
  deletedOrgId String?   @db.Uuid

  // Location
  country String?
  state   String?
  city    String?

  // Meeting preference
  meetingPreference ProviderEnum?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  loginHistory           LoginHistory[]
  oauthAccounts          OAuthAccount[]
  organizationMembers    OrganizationMember[]
  refreshTokens          RefreshToken[]
  sessions               Session[]
  calendarEvents         GoogleCalendarEvent[]
  googleCalendarSyncLogs GoogleCalendarSyncLog[]
  notifications          Notification[]

  // Digital Cards
  cards        Card[]
  cardContacts CardContact[]

  // Availability & Booking
  availabilitySchedules AvailabilitySchedule[]
  eventTypes            EventType[]

  // Meetings (user-level)
  meetingsCreated             Meeting[]                  @relation("MeetingCreatedBy")
  meetingParticipations       MeetingParticipant[]
  meetingStateChanges         MeetingStateHistory[]      @relation("MeetingStateChanges")
  rescheduleRequestsCreated   MeetingRescheduleRequest[] @relation("RescheduleRequestedBy")
  rescheduleRequestsResponded MeetingRescheduleRequest[] @relation("RescheduleRespondedBy")
  meetingSpeakers             MeetingSpeaker[]
}

model Session {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  deviceInfo     String?
  ipAddress      String?
  createdAt      DateTime @default(now())
  expiredAt      DateTime
  lastAccessedAt DateTime
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginHistory {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @db.Uuid
  ipAddress     String
  deviceInfo    String
  loginTime     DateTime      @default(now())
  success       Boolean
  failureReason String?
  loginMethod   LoginMethod   @default(OAUTH)
  provider      ProviderEnum?
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loginTime])
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  token      String
  revoked    Boolean  @default(false)
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  deviceInfo String
  ipAddress  String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthAccount {
  id             String                  @id @default(uuid()) @db.Uuid
  provider       ProviderEnum
  providerId     String
  accessToken    String
  refreshToken   String
  expiry         Int
  scopes         String[]
  createdAt      DateTime                @default(now())
  userId         String                  @db.Uuid
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendarEvents GoogleCalendarEvent[]
  syncLogs       GoogleCalendarSyncLog[]

  @@unique([provider, providerId])
}

model OrgInvite {
  id           String       @id @default(uuid()) @db.Uuid
  orgId        String       @db.Uuid
  invitedEmail String
  invitedRole  UserRoleEnum
  invitedById  String       @db.Uuid  // who sent the invite
  token        String       @unique
  expiresAt    DateTime
  acceptedAt   DateTime?              // null = pending, set = accepted
  createdAt    DateTime     @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, invitedEmail])
  @@index([token])
  @@index([orgId])
}

// ================================
// ORGANIZATION & MEMBERSHIP
// ================================

model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Organization details (JSON for flexibility)
  organizationDetails Json

  // Email sender configuration for notifications (Brevo)
  brevoApiKey String?
  senderEmail String?
  senderName  String?

  // Organization branding
  orgLogoUrl String?
  brandColor String?

  // Personal workspace flag (true = personal workspace, false = team org)
  isPersonal Boolean @default(false)

  // Default meeting provider preference
  defaultMeetingProvider ProviderEnum?

  // Relations
  members              OrganizationMember[]
  invites              OrgInvite[]
  notificationSettings OrgNotificationSettings?
  notificationPreferences NotificationPreference[]
  notificationLogs     NotificationLog[]
}

model OrganizationMember {
  id          String       @id @default(uuid()) @db.Uuid
  orgId       String       @db.Uuid
  userId      String       @db.Uuid
  accessLevel UserRoleEnum @default(MEMBER)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  organization Organization @relation(fields: [orgId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

// ================================
// GOOGLE CALENDAR INTEGRATION
// ================================

model GoogleCalendarEvent {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  oauthAccountId   String   @db.Uuid
  googleEventId    String
  summary          String?
  description      String?
  location         String?
  startTime        DateTime
  endTime          DateTime
  status           String?
  attendees        Json?
  isAllDay         Boolean  @default(false)
  recurring        Boolean  @default(false)
  recurringEventId String?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastSyncedAt     DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  oauthAccount OAuthAccount @relation(fields: [oauthAccountId], references: [id], onDelete: Cascade)

  @@unique([oauthAccountId, googleEventId])
  @@index([userId])
  @@index([startTime])
}

model GoogleCalendarSyncLog {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  oauthAccountId    String   @db.Uuid
  lastSyncTime      DateTime @default(now())
  nextSyncToken     String?
  fullSyncCompleted Boolean  @default(false)
  status            String   @default("PENDING")
  errorMessage      String?
  eventsSynced      Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  oauthAccount OAuthAccount @relation(fields: [oauthAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, oauthAccountId])
  @@index([oauthAccountId, lastSyncTime])
}

// ================================
// CALENDAR & MEETING MANAGEMENT
// ================================

model Meeting {
  id            String        @id @default(uuid()) @db.Uuid
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  timezone      String        @default("UTC")
  mode          MeetingMode
  status        MeetingStatus @default(PENDING_ACCEPTANCE)
  location      String?       // For in-person meetings
  meetingLink   String?       // Zoom/GMeet URL
  meetingProvider ProviderEnum? // Which provider generated the link
  videoMeetingId  String?       // External meeting ID (Zoom meeting ID, Google Meet ID)
  googleEventId String?
  recordingLink String?
  notes         String?

  // Event type reference (for booking-created meetings)
  eventTypeId String? @db.Uuid

  // Guest booking info (for public bookings)
  guestEmail   String?
  guestName    String?
  guestMessage String?

  // Tracking (user-level)
  createdById String  @db.Uuid
  isDeleted   Boolean @default(false)
  deletedAt   DateTime?
  deletedBy   String? @db.Uuid

  // Transcription processing status
  transcriptionStatus TranscriptionStatus @default(NONE)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  eventType          EventType?                 @relation(fields: [eventTypeId], references: [id])
  createdBy          User                       @relation("MeetingCreatedBy", fields: [createdById], references: [id])
  participants       MeetingParticipant[]
  guests             MeetingGuest[]
  stateHistory       MeetingStateHistory[]
  rescheduleRequests MeetingRescheduleRequest[]

  // Smart Meeting Assistant relations
  recording    MeetingRecording?
  speakers     MeetingSpeaker[]
  actionItems  MeetingActionItem[]
  meetingNotes MeetingNote[]
  aiSummary    MeetingAISummary?

  @@index([createdById])
  @@index([startTime])
  @@index([googleEventId])
  @@index([status, isDeleted])
  @@index([guestEmail])
  @@index([transcriptionStatus])
  @@index([eventTypeId])
}

model MeetingParticipant {
  id              String          @id @default(uuid()) @db.Uuid
  meetingId       String          @db.Uuid
  userId          String          @db.Uuid
  participantType ParticipantType
  responseStatus  ResponseStatus  @default(PENDING)
  respondedAt     DateTime?
  joinedAt        DateTime?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@index([userId])
  @@index([meetingId])
}

model MeetingGuest {
  id             String         @id @default(uuid()) @db.Uuid
  meetingId      String         @db.Uuid
  email          String
  name           String?
  responseStatus ResponseStatus @default(PENDING)
  respondedAt    DateTime?
  createdAt      DateTime       @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, email])
  @@index([meetingId])
  @@index([email])
}

model MeetingStateHistory {
  id          String         @id @default(uuid()) @db.Uuid
  meetingId   String         @db.Uuid
  fromStatus  MeetingStatus?
  toStatus    MeetingStatus
  changedById String         @db.Uuid
  reason      String?
  changedAt   DateTime       @default(now())

  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  changedBy User    @relation("MeetingStateChanges", fields: [changedById], references: [id])

  @@index([meetingId])
  @@index([toStatus])
}

model MeetingRescheduleRequest {
  id                String         @id @default(uuid()) @db.Uuid
  meetingId         String         @db.Uuid
  requestedById     String         @db.Uuid
  proposedStartTime DateTime
  proposedEndTime   DateTime
  reason            String?
  status            ResponseStatus @default(PENDING)
  respondedById     String?        @db.Uuid
  respondedAt       DateTime?
  responseNotes     String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  meeting     Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  requestedBy User    @relation("RescheduleRequestedBy", fields: [requestedById], references: [id])
  respondedBy User?   @relation("RescheduleRespondedBy", fields: [respondedById], references: [id])

  @@index([meetingId])
  @@index([status])
}

// ================================
// AVAILABILITY & SCHEDULING
// ================================

model AvailabilitySchedule {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  name      String   @default("Working Hours")
  timezone  String   @default("UTC")
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  slots        ScheduleAvailability[]
  overrides    ScheduleOverride[]
  blockedTimes ScheduleBlockedTime[]
  eventTypes   EventType[]

  @@index([userId, isDefault])
  @@index([userId, isActive])
}

model ScheduleAvailability {
  id         String    @id @default(uuid()) @db.Uuid
  scheduleId String    @db.Uuid
  dayOfWeek  DayOfWeek
  startTime  String    // "HH:MM"
  endTime    String    // "HH:MM"
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  schedule AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, dayOfWeek, startTime, endTime])
  @@index([scheduleId, isActive])
}

model ScheduleOverride {
  id         String   @id @default(uuid()) @db.Uuid
  scheduleId String   @db.Uuid
  date       DateTime
  startTime  String   // "HH:MM"
  endTime    String   // "HH:MM"
  isActive   Boolean  @default(true)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  schedule AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId, date])
  @@index([scheduleId, isActive])
}

model ScheduleBlockedTime {
  id             String         @id @default(uuid()) @db.Uuid
  scheduleId     String         @db.Uuid
  startTime      DateTime
  endTime        DateTime
  reason         String?
  recurrenceRule RecurrenceRule @default(NONE)
  recurrenceEnd  DateTime?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  schedule AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId, startTime, endTime])
  @@index([scheduleId, isActive])
}

// ================================
// EVENT TYPES
// ================================

model EventType {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @db.Uuid
  title       String       // "30 Minute Meeting"
  slug        String       // "30-min-meeting"
  description String?
  duration    Int          // minutes (e.g. 30)
  scheduleId  String       @db.Uuid
  bookingModel BookingModel @default(ONE_ON_ONE)

  // Booking constraints
  bufferBefore Int @default(0)  // minutes before meeting
  bufferAfter  Int @default(0)  // minutes after meeting
  minNotice    Int @default(24) // minimum hours notice before booking
  maxAdvance   Int @default(60) // maximum days in advance

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule AvailabilitySchedule @relation(fields: [scheduleId], references: [id])
  meetings Meeting[]

  @@unique([userId, slug])
  @@index([userId, isActive])
  @@index([scheduleId])
}

// ================================
// TRANSCRIPTION & AI (Smart Meeting Assistant)
// ================================

model MeetingRecording {
  id        String  @id @default(uuid()) @db.Uuid
  meetingId String  @unique @db.Uuid
  
  gcsPath   String  // Path in Google Cloud Storage
  duration  Int     // Duration in seconds
  fileSize  Int     // File size in bytes
  fileName  String

  uploadedBy String   @db.Uuid
  uploadedAt DateTime @default(now())

  meeting    Meeting     @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  transcript MeetingTranscript?

  @@index([meetingId])
}

model MeetingTranscript {
  id          String  @id @default(uuid()) @db.Uuid
  recordingId String  @unique @db.Uuid

  fullText String   // Complete transcript text

  deepgramJobId String?   // Track Deepgram async job
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  recording MeetingRecording     @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  segments  TranscriptSegment[]

  @@index([recordingId])
}

model TranscriptSegment {
  id           String @id @default(uuid()) @db.Uuid
  transcriptId String @db.Uuid

  speaker   String  // "Speaker 1", "Speaker 2", etc.
  text      String
  startTime Float   // seconds
  endTime   Float   // seconds

  transcript MeetingTranscript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)

  @@index([transcriptId])
  @@index([speaker])
}

model MeetingSpeaker {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @db.Uuid

  speakerLabel String  // "Speaker 1", "Speaker 2", etc. (from Deepgram diarization)
  displayName  String? // User-provided name
  role         String? // Custom role (e.g., "consultant", "client")

  userId String? @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@unique([meetingId, speakerLabel])
  @@index([meetingId])
  @@index([userId])
}

model MeetingActionItem {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @db.Uuid

  title       String
  description String?
  owner       String @db.Uuid // userId
  category    ActionItemCategory

  suggestedStartDate DateTime?
  suggestedEndDate   DateTime?
  assignedTo         String?   @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([owner])
}

model MeetingNote {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @db.Uuid

  content   String
  author    String @db.Uuid // userId
  timestamp Float? // seconds into the meeting

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([author])
}

model MeetingAISummary {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @unique @db.Uuid

  summary    String
  keyPoints  String[]
  
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

// ================================
// NOTIFICATION SYSTEM
// ================================

model NotificationLog {
  id             String             @id @default(uuid()) @db.Uuid
  orgId          String?            @db.Uuid
  senderEmail    String
  recipientEmail String
  recipientRole  String
  event          String
  payload        Json
  status         NotificationLogStatus
  reason         String?
  vendorResponse Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([event])
  @@index([status])
  @@index([createdAt])
}

model OrgNotificationSettings {
  id    String @id @default(uuid()) @db.Uuid
  orgId String @unique @db.Uuid

  notificationsEnabled Boolean                     @default(true)
  disabledRoles        NotificationRecipientType[] @default([])
  emailEnabled         Boolean                     @default(true)
  inAppEnabled         Boolean                     @default(true)

  defaultSenderEmail String?
  defaultSenderName  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model NotificationPreference {
  id    String @id @default(uuid()) @db.Uuid
  orgId String @db.Uuid

  eventType     NotificationEventType
  recipientType NotificationRecipientType

  emailEnabled Boolean @default(true)
  inAppEnabled Boolean @default(true)

  isEnabled       Boolean @default(true)
  emailTemplateId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, eventType, recipientType])
  @@index([orgId])
  @@index([eventType])
  @@index([recipientType])
}

// In-App Notifications (user's notification inbox)
model Notification {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  orgId  String? @db.Uuid

  type    NotificationEventType
  title   String
  message String
  data    Json?   // Additional data (meetingId, etc.)
  
  isRead  Boolean @default(false)
  readAt  DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([orgId])
}

// ================================
// DIGITAL CARDS
// ================================

model Card {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  // Card content
  slug        String  // "default", "work", "startup"
  displayName String  // name shown on card (can differ from user.name)
  title       String? // "Software Engineer @ Acme"
  bio         String?
  avatarUrl   String?
  coverUrl    String? // banner/cover image

  // Structured fields
  links         Json @default("[]")  // [{type, url, label, icon}]
  contactFields Json @default("{}")  // {phone, email, location, website}

  // Theme & customization
  theme Json @default("{}") // {primaryColor, backgroundColor, fontFamily, layout, darkMode}

  // Template system
  templateId      String  @default("executive") // "executive" | "classic-bold" | "minimal"
  showQr          Boolean @default(true)        // Show QR code on back face
  htmlContent     String? @db.Text              // Generated front-face HTML
  htmlBackContent String? @db.Text              // Generated back-face HTML

  // Card state
  isDefault Boolean @default(false) // shown at /username
  isActive  Boolean @default(true)  // can be paused

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts CardContact[]
  views    CardView[]

  @@unique([userId, slug])
  @@index([userId, isActive])
  @@index([userId, isDefault])
}

model CardContact {
  id     String @id @default(uuid()) @db.Uuid
  cardId String @db.Uuid
  userId String @db.Uuid // card owner

  // Contact info submitted by scanner
  name    String
  email   String?
  phone   String?
  company String?
  note    String?

  // Organization & tagging
  tags String[] @default([]) // e.g., ["TechConf 2026", "networking"]

  // Tracking
  scannedAt      DateTime @default(now())
  savedByScanner Boolean  @default(false) // did they also save the card?

  // Relations
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([userId, scannedAt])
  @@index([email])
}

model CardView {
  id     String @id @default(uuid()) @db.Uuid
  cardId String @db.Uuid

  // Analytics data
  ipHash    String?  // hashed IP for unique visitor tracking (privacy-friendly)
  userAgent String?
  referrer  String?
  country   String?
  city      String?

  // Link click tracking
  clickedLink String? // which link was clicked (null = just a view)

  viewedAt DateTime @default(now())

  // Relations
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, viewedAt])
  @@index([cardId, clickedLink])
}

// ================================
// ENUMS
// ================================

enum LoginMethod {
  OAUTH
}

enum ProviderEnum {
  GOOGLE
  ZOOM
}

enum UserRoleEnum {
  OWNER
  ADMIN
  MEMBER
}

enum SyncStatus {
  SUCCESS
  FAILED
  PENDING
}

enum MeetingMode {
  ONLINE
  IN_PERSON
}

enum MeetingStatus {
  CREATED
  PENDING_ACCEPTANCE
  ACCEPTED
  DECLINED
  COMPLETED
  CANCELLED
  RESCHEDULING_REQUESTED
}

enum ParticipantType {
  ORGANIZER
  ATTENDEE
}

enum ResponseStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum RecurrenceRule {
  NONE
  WEEKLY
  MONTHLY
}

enum TranscriptionStatus {
  NONE        // No recording uploaded
  UPLOADED    // Recording uploaded to GCS
  PROCESSING  // Transcription in progress
  COMPLETED   // Transcription complete
  FAILED      // Transcription failed
}

enum ActionItemCategory {
  PARTICIPANT_TASK
  SHARED_TASK
  DOCUMENT_REQUIRED
  UPCOMING_EVENT
  OTHER
}

enum NotificationLogStatus {
  SENT
  FAILED
  SKIPPED
  BLOCKED
}

enum NotificationEventType {
  TESTING_MAIL
  MEETING_SCHEDULED
  MEETING_RESCHEDULED
  MEETING_CANCELLED
  MEETING_REMINDER
  NEW_TEAM_MEMBER
  TRANSCRIPTION_COMPLETE
  ACTION_ITEMS_GENERATED
}

enum NotificationChannel {
  EMAIL
  IN_APP
}

enum NotificationRecipientType {
  ADMIN
  MEMBER
  ALL
}

enum BookingModel {
  ONE_ON_ONE
  ROUND_ROBIN   // Phase 2 - team
  COLLECTIVE    // Phase 2 - team
}
