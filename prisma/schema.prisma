generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================
// CORE USER & AUTHENTICATION
// ================================

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  username        String?   @unique
  emailVerified   Boolean   @default(false)
  name            String
  avatarUrl       String?
  countryCode     String?
  phoneNumber     String?
  lastLoginAt     DateTime?
  isActive        Boolean   @default(true)
  activeSessionId String?   @db.Uuid
  timezone        String    @default("UTC")

  // Soft delete fields
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedById String?   @db.Uuid

  // Location
  country String?
  state   String?
  city    String?

  // Billing (Phase 4)
  plan Plan @default(FREE)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  loginHistory  LoginHistory[]
  oauthAccounts OAuthAccount[]
  refreshTokens RefreshToken[]
  sessions      Session[]

  // Digital Cards
  cards        Card[]
  cardContacts CardContact[]

  // Meetings (user-level)
  meetingsCreated       Meeting[]             @relation("MeetingCreatedBy")
  meetingParticipations MeetingParticipant[]
  meetingStateChanges   MeetingStateHistory[] @relation("MeetingStateChanges")
  meetingSpeakers       MeetingSpeaker[]
  tasks                 Task[]
  assignedTasks         Task[]    @relation("TaskAssignee")
  meetingShares         MeetingShare[]
  tags                  Tag[]
  meetingAttachments    MeetingAttachment[]
  meetingNotes          MeetingNote[]
  recordings            MeetingRecording[]

  // Scheduling (Phase 1.2)
  settings              UserSettings?
  eventTypes            EventType[]
  availabilitySchedules AvailabilitySchedule[]
  bookings              Booking[]

  // Billing (Phase 4 + Phase 6 P5.8)
  // P5.8 — `UserUsage` is no longer 1:1 with User. Each user has one
  // personal row plus one row per team they own. Iterate via `usage[]`.
  usage        UserUsage[]
  subscription Subscription?

  // AI Conversations (Phase 4.2)
  askAIConversations AskAIConversation[]

  // Google Calendar Push Sync (Phase 4.3)
  gcalSyncState GCalSyncState?

  // In-App Notifications (Phase 4.9)
  notifications Notification[]

  // Encryption at Rest (Phase 5)
  // wrappedDek is null only for users created before Phase 5 — backfill script fills it in.
  wrappedDek Bytes?
  dekVersion Int              @default(1)
  dekHistory UserDekHistory[]

  // Teams (Phase 6)
  ownedTeams           Team[]       @relation("TeamOwner")
  teamMemberships      TeamMember[]
  teamInvitesSent      TeamInvite[] @relation("TeamInviteSender")
  teamInvitesReceived  TeamInvite[] @relation("TeamInviteRecipient")

  @@index([activeSessionId])
  @@index([createdAt])
  @@index([plan])
}

// Intentionally omits isDeleted/deletedAt/updatedAt:
// - Rows are append-only (a new row is inserted on each DEK rotation, never updated)
// - Hard-deleted via onDelete: Cascade when User is deleted — this is the crypto-shredding
//   guarantee. A soft-delete would leave the wrappedDek material in the DB, defeating the shred.
model UserDekHistory {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  version    Int
  wrappedDek Bytes
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, version])
  @@index([userId])
}

model Session {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  deviceInfo     String?
  ipAddress      String?
  createdAt      DateTime @default(now())
  expiredAt      DateTime
  lastAccessedAt DateTime
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiredAt])
}

model LoginHistory {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @db.Uuid
  ipAddress     String
  deviceInfo    String
  loginTime     DateTime      @default(now())
  success       Boolean
  failureReason String?
  loginMethod   LoginMethod   @default(OAUTH)
  provider      ProviderEnum?
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loginTime])
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  token      String
  revoked    Boolean  @default(false)
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  deviceInfo String
  ipAddress  String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model OAuthAccount {
  id           String       @id @default(uuid()) @db.Uuid
  provider     ProviderEnum
  providerId   String
  accessToken  Bytes // Encrypted OAuth access token (AES-256-GCM, Phase 5)
  refreshToken Bytes? // Encrypted OAuth refresh token — null when Google didn't issue one (only first consent)
  expiry       Int
  scopes       String[]
  createdAt    DateTime     @default(now())
  userId       String       @db.Uuid
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
}

// ================================
// MEETING MANAGEMENT
// ================================

model Meeting {
  id          String        @id @default(uuid()) @db.Uuid
  title       String
  description String?
  type        MeetingType   @default(SCHEDULED)
  startTime   DateTime
  endTime     DateTime
  timezone    String        @default("UTC")
  status      MeetingStatus @default(CREATED)
  location    String?
  notes       String?

  // Tracking
  createdById String    @db.Uuid
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedBy   String?   @db.Uuid

  // Teams (Phase 6) — null = personal meeting
  teamId String? @db.Uuid

  // Transcription processing status
  transcriptionStatus TranscriptionStatus @default(NONE)

  // Recall.ai bot ID — populated when a bot joins an online meeting.
  // Used to match Recall webhook events back to this meeting.
  recallBotId String?

  // Google Calendar integration
  meetLink      String? // Auto-generated Google Meet URL (Phase 1.3)
  googleEventId String? // GCal event ID for write sync (Phase 1.3)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  createdBy    User                  @relation("MeetingCreatedBy", fields: [createdById], references: [id])
  team         Team?                 @relation(fields: [teamId], references: [id], onDelete: SetNull)
  participants MeetingParticipant[]
  stateHistory MeetingStateHistory[]

  // Smart Meeting Assistant relations
  recording          MeetingRecording?
  speakers           MeetingSpeaker[]
  tasks              Task[]
  meetingNotes       MeetingNote[]
  aiSummary          MeetingAISummary?
  aiContents         MeetingAIContent[]
  share              MeetingShare?
  tags               MeetingTag[]
  attachments        MeetingAttachment[]
  booking            Booking?
  askAIConversations AskAIConversation[]

  @@index([createdById])
  @@index([createdAt])
  @@index([startTime])
  @@index([status, isDeleted])
  @@index([transcriptionStatus])
  @@index([type, isDeleted])
  @@index([recallBotId])
  @@index([googleEventId])
  @@index([teamId, isDeleted, createdAt(sort: Desc)]) // dashboard "list my team's meetings" hot path
}

model MeetingParticipant {
  id              String          @id @default(uuid()) @db.Uuid
  meetingId       String          @db.Uuid
  userId          String?         @db.Uuid
  guestEmail      Bytes? // Encrypted guest email (AES-256-GCM, Phase 5)
  participantType ParticipantType
  joinedAt        DateTime?
  cardId          String?         @db.Uuid

  // Deterministic blind index — exact-match lookup for encrypted guestEmail
  guestEmailBidx Bytes?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])
  card    Card?   @relation(fields: [cardId], references: [id])

  @@index([userId])
  @@index([guestEmailBidx])
  @@index([meetingId])
  @@index([cardId])
}

model MeetingStateHistory {
  id          String         @id @default(uuid()) @db.Uuid
  meetingId   String         @db.Uuid
  fromStatus  MeetingStatus?
  toStatus    MeetingStatus
  changedById String         @db.Uuid
  reason      String?
  changedAt   DateTime       @default(now())

  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  changedBy User    @relation("MeetingStateChanges", fields: [changedById], references: [id])

  @@index([meetingId])
  @@index([toStatus])
  @@index([changedById])
}

// ================================
// TRANSCRIPTION & AI (Smart Meeting Assistant)
// ================================

model MeetingRecording {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @unique @db.Uuid

  gcsPath  String // Path in Google Cloud Storage
  duration Int // Duration in seconds
  fileSize Int // File size in bytes
  fileName String

  uploadedBy String   @db.Uuid
  uploadedAt DateTime @default(now())

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  uploader   User               @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)
  meeting    Meeting            @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  transcript MeetingTranscript?

  @@index([meetingId])
  @@index([uploadedBy])
}

model MeetingTranscript {
  id          String @id @default(uuid()) @db.Uuid
  recordingId String @unique @db.Uuid

  fullText Bytes? // Encrypted transcript text (AES-256-GCM, Phase 5)

  deepgramJobId String? // Track Deepgram async job
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  recording MeetingRecording    @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  segments  TranscriptSegment[]

  @@index([recordingId])
  @@index([recordingId, isDeleted])
}

model TranscriptSegment {
  id           String @id @default(uuid()) @db.Uuid
  transcriptId String @db.Uuid

  speaker   String // "Speaker 1", "Speaker 2", etc.
  text      Bytes? // Encrypted segment text (AES-256-GCM, Phase 5)
  startTime Float // seconds
  endTime   Float // seconds

  transcript MeetingTranscript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)

  @@index([transcriptId])
  @@index([speaker])
  @@index([startTime])
  @@index([transcriptId, startTime])
}

model MeetingSpeaker {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @db.Uuid

  speakerLabel String // "Speaker 1", "Speaker 2", etc. (from Deepgram diarization)
  displayName  String? // User-provided name
  role         String? // Custom role (e.g., "consultant", "client")

  userId String? @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@unique([meetingId, speakerLabel])
  @@index([meetingId])
  @@index([userId])
}

model Task {
  id        String  @id @default(uuid()) @db.Uuid
  userId    String  @db.Uuid
  meetingId String? @db.Uuid

  title         String
  description   Bytes? // Encrypted task description (AES-256-GCM, Phase 5)
  isCompleted   Boolean       @default(false) // PHASE-OUT: keep in sync with status field
  completedAt   DateTime? // PHASE-OUT: set when status = DONE
  dueDate       DateTime?
  scheduledTime DateTime?
  priority      TaskPriority?
  source        TaskSource    @default(MANUAL)

  // Phase 3 additions
  status            TaskStatus @default(TODO)
  sortOrder         Int        @default(0)
  parentTaskId      String?    @db.Uuid
  cardId            String?    @db.Uuid
  transcriptContext String? // The transcript sentence that generated this task (AI_EXTRACTED only)
  durationMinutes   Int?       @default(30) // Task duration in minutes (5–480)
  googleEventId     String? // GCal time-block event ID (set when task is blocked in Google Calendar)

  // Phase 3.2 — Recurring tasks
  recurringRule     String? // RRULE string e.g. "FREQ=DAILY", "FREQ=WEEKLY", "FREQ=MONTHLY"
  recurringParentId String? @db.Uuid // Points to the root recurring task (never the previous sibling)

  // Teams (Phase 6) — null = personal task
  teamId String? @db.Uuid

  // Task assignment (Phase 6 — Teams)
  assigneeId   String? @db.Uuid
  assigneeName String? // Snapshot at assignment time — survives membership removal

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  team              Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  meeting           Meeting?  @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  taskTags          TaskTag[]
  parent            Task?     @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks          Task[]    @relation("TaskSubtasks")
  card              Card?     @relation(fields: [cardId], references: [id], onDelete: SetNull)
  recurringParent   Task?     @relation("RecurringTasks", fields: [recurringParentId], references: [id], onDelete: SetNull)
  recurringChildren Task[]    @relation("RecurringTasks")
  assignee          User?     @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([meetingId])
  @@index([userId, isDeleted])
  @@index([dueDate])
  @@index([scheduledTime])
  @@index([isCompleted])
  @@index([source])
  @@index([status])
  @@index([userId, sortOrder])
  @@index([parentTaskId])
  @@index([cardId])
  @@index([userId, status, isDeleted])
  @@index([userId, cardId, isDeleted])
  @@index([googleEventId])
  @@index([recurringParentId])
  @@index([teamId, isDeleted, createdAt(sort: Desc)]) // team dashboard hot path
  @@index([assigneeId])
}

model TaskTag {
  taskId    String   @db.Uuid
  tagId     String   @db.Uuid
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([taskId])
  @@index([tagId])
}

model MeetingNote {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @db.Uuid

  content   Bytes // Encrypted note content (AES-256-GCM, Phase 5)
  author    String? @db.Uuid // userId — nullable so notes survive user deletion
  timestamp Float? // seconds into the meeting

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting    Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  authorUser User?   @relation(fields: [author], references: [id], onDelete: SetNull)

  @@index([meetingId])
  @@index([author])
  @@index([meetingId, isDeleted])
}

model MeetingAISummary {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @unique @db.Uuid

  summary   Bytes // Encrypted summary text (AES-256-GCM, Phase 5)
  keyPoints Bytes? // Encrypted JSON array of key points (AES-256-GCM, Phase 5)

  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([meetingId, isDeleted])
}

model MeetingAIContent {
  id        String        @id @default(uuid()) @db.Uuid
  meetingId String        @db.Uuid
  type      AIContentType
  content   Bytes // Encrypted AI-generated content (AES-256-GCM, Phase 5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, type])
  @@index([meetingId])
}

// ================================
// ASK AI CONVERSATIONS (Phase 4.2)
// ================================

model AskAIConversation {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @db.Uuid
  userId    String @db.Uuid

  meeting  Meeting        @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AskAIMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

model AskAIMessage {
  id             String @id @default(uuid()) @db.Uuid
  conversationId String @db.Uuid

  role    String // "user" | "assistant"
  content Bytes // Encrypted message content (AES-256-GCM, Phase 5)

  conversation AskAIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

// ================================
// GOOGLE CALENDAR PUSH SYNC (Phase 4.3)
// ================================

model GCalSyncState {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid

  channelId  String   @unique // UUID we generate — used as channel identifier with Google
  resourceId String? // Returned by Google after watch() — needed to stop channel
  expiration DateTime // When Google expires this channel (max 30 days)
  syncToken  String? // Incremental sync token from last successful events.list call

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiration])
  @@index([channelId])
}

model MeetingShare {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @unique @db.Uuid
  userId    String @db.Uuid

  shortId        String  @unique
  isPublic       Boolean @default(false)
  showTranscript Boolean @default(true)
  showSummary    Boolean @default(true)
  showTasks      Boolean @default(true)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Note: onDelete: Cascade only applies to hard deletes. Normal operation
  // uses soft deletes (isDeleted: true). HARD_DELETE_ENABLED is false by default.
  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([shortId])
  @@index([meetingId])
  @@index([userId])
  @@index([isPublic])
}

// ================================
// DIGITAL CARDS
// ================================

model Card {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  // Card content
  slug        String // "default", "work", "startup"
  displayName String // name shown on card (can differ from user.name)
  title       String? // "Software Engineer @ Acme"
  bio         String?
  avatarUrl   String?
  coverUrl    String? // banner/cover image

  // Structured fields
  links         Json @default("[]") // [{type, url, label, icon}]
  contactFields Json @default("{}") // {phone, email, location, website}

  // Theme & customization
  theme Json @default("{}") // {primaryColor, backgroundColor, fontFamily, layout, darkMode}

  // Template system
  templateId      String  @default("executive") // "executive" | "classic-bold" | "minimal"
  showQr          Boolean @default(true) // Show QR code on back face
  htmlContent     String? @db.Text // Generated front-face HTML
  htmlBackContent String? @db.Text // Generated back-face HTML

  // Card state
  isDefault Boolean @default(false) // shown at /username
  isActive  Boolean @default(true) // can be paused

  // Teams (Phase 6) — null = personal card
  teamId     String?  @db.Uuid
  isTeamCard Boolean  @default(false) // true = designated team card; only one per team

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  team                Team?                @relation(fields: [teamId], references: [id], onDelete: SetNull)
  contacts            CardContact[]
  views               CardView[]
  tags                CardTag[]
  tasks               Task[]
  meetingParticipants MeetingParticipant[]

  @@unique([userId, slug])
  @@index([slug])
  @@index([userId])
  @@index([userId, isActive])
  @@index([userId, isDefault])
  @@index([teamId, isDeleted])
}

model CardContact {
  id     String @id @default(uuid()) @db.Uuid
  cardId String @db.Uuid
  userId String @db.Uuid // card owner

  // Contact info submitted by scanner
  // name and company stay plaintext for ILIKE search and Big Brain indexing (CLAUDE.md)
  name    String
  email   Bytes? // Encrypted contact email (AES-256-GCM, Phase 5)
  phone   Bytes? // Encrypted contact phone (AES-256-GCM, Phase 5)
  company String?
  note    Bytes? // Encrypted contact note (AES-256-GCM, Phase 5)

  // Organization & tagging
  tags String[] @default([]) // e.g., ["TechConf 2026", "networking"]

  // Tracking
  scannedAt      DateTime @default(now())
  savedByScanner Boolean  @default(false) // did they also save the card?

  // Soft delete (Phase 4.4)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  // Deterministic blind indexes — exact-match lookup for encrypted fields
  emailBidx Bytes? // HMAC-SHA256 of normalised email
  phoneBidx Bytes? // HMAC-SHA256 of normalised phone

  // Relations
  contactTags ContactTag[]
  card        Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([userId, scannedAt])
  @@index([emailBidx])
  @@index([phoneBidx])
  @@index([userId, isDeleted])
}

model CardView {
  id     String @id @default(uuid()) @db.Uuid
  cardId String @db.Uuid

  // Analytics data
  ipHash    String? // hashed IP for unique visitor tracking (privacy-friendly)
  userAgent String?
  referrer  String?
  country   String?
  city      String?

  // Link click tracking
  clickedLink String? // which link was clicked (null = just a view)

  viewedAt DateTime @default(now())

  // Relations
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, viewedAt])
  @@index([cardId, clickedLink])
}

// ================================
// ATTACHMENTS
// ================================

model MeetingAttachment {
  id        String @id @default(uuid()) @db.Uuid
  meetingId String @db.Uuid
  userId    String @db.Uuid

  type     AttachmentType
  name     String
  url      String? // LINK: raw URL
  gcsPath  String? // FILE/PHOTO: GCS object path
  mimeType String?
  size     Int? // bytes

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Note: onDelete: Cascade only applies to hard deletes. Normal operation
  // uses soft deletes (isDeleted: true). HARD_DELETE_ENABLED is false by default.
  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([meetingId, isDeleted])
  @@index([userId])
}

// ================================
// TAGS (Universal)
// ================================

model Tag {
  id     String  @id @default(uuid()) @db.Uuid
  userId String  @db.Uuid // creator — even on team tags (audit/attribution)
  teamId String? @db.Uuid // Phase 6 P5.5.a — null for personal tags, set for team-scoped
  name   String
  color  String  @default("#6b7280")

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  team        Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  meetingTags MeetingTag[]
  cardTags    CardTag[]
  taskTags    TaskTag[]
  contactTags ContactTag[]

  // Phase 6 P5.5.a — `@@unique([userId, name])` dropped in favour of two
  // partial unique indexes (added in raw SQL by the migration):
  //   Tag_user_personal_unique: (userId, name) WHERE teamId IS NULL AND isDeleted = false
  //   Tag_team_unique:          (teamId, name) WHERE teamId IS NOT NULL AND isDeleted = false
  // Partial indexes let personal "Important" and team "Important" co-exist.
  @@index([userId])
  @@index([userId, isDeleted])
  @@index([teamId, isDeleted])
}

model MeetingTag {
  meetingId String @db.Uuid
  tagId     String @db.Uuid

  createdAt DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([meetingId, tagId])
  @@index([meetingId])
  @@index([tagId])
}

model CardTag {
  cardId String @db.Uuid
  tagId  String @db.Uuid

  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([cardId, tagId])
  @@index([cardId])
  @@index([tagId])
}

model ContactTag {
  contactId String @db.Uuid
  tagId     String @db.Uuid

  createdAt DateTime @default(now())

  contact CardContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([contactId])
  @@index([tagId])
}

// ================================
// SCHEDULING (Phase 1.2)
// ================================

model UserSettings {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid

  // Scheduling
  schedulingEnabled Boolean @default(true)
  maxWindowDays     Int     @default(60)
  defaultBufferMins Int     @default(15)

  // Integrations
  googleCalendarSyncEnabled Boolean @default(false)
  googleCalendarEmail       String?
  recallEnabled             Boolean @default(false)

  // AI & Transcription
  autoTranscribe  Boolean @default(true)
  autoAIProcess   Boolean @default(true)
  defaultLanguage String  @default("en")

  // Email Notifications (Phase 3.3)
  emailNotificationsEnabled Boolean @default(true) // master toggle
  bookingEmailsEnabled      Boolean @default(true) // booking received/confirmed/cancelled
  meetingReadyEmailEnabled  Boolean @default(true) // AI processing complete
  dailyDigestEnabled        Boolean @default(false) // 8am daily task digest

  // In-App Notifications (Phase 4.9)
  inAppNotificationsEnabled Boolean @default(true) // master toggle
  inAppBookingEnabled       Boolean @default(true) // booking received/cancelled/reminder
  inAppMeetingReadyEnabled  Boolean @default(true) // AI processing complete
  inAppTaskDueEnabled       Boolean @default(true) // task due soon
  inAppTaskAssignedEnabled  Boolean @default(true) // task assigned to me

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
}

model EventType {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @db.Uuid
  title          String
  slug           String
  description    String?
  duration       Int // minutes
  locationType   LocationType @default(IN_PERSON)
  meetingLink    String? // Zoom/Meet URL — ONLINE only
  bufferBefore   Int          @default(0) // minutes
  bufferAfter    Int          @default(0) // minutes
  minNoticeHours Int          @default(24) // hours
  maxPerDay      Int? // null = unlimited
  isActive       Boolean      @default(true)

  // Linked availability schedule — null = use user's default schedule
  availabilityScheduleId String? @db.Uuid

  // Teams (Phase 6) — null = personal event type
  teamId String? @db.Uuid

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  team                 Team?                 @relation(fields: [teamId], references: [id], onDelete: SetNull)
  availabilitySchedule AvailabilitySchedule? @relation(fields: [availabilityScheduleId], references: [id])
  bookings             Booking[]

  @@unique([userId, slug])
  @@index([userId, isActive, isDeleted])
  @@index([availabilityScheduleId])
  @@index([teamId, isDeleted])
}

model AvailabilitySchedule {
  id        String  @id @default(uuid()) @db.Uuid
  userId    String  @db.Uuid
  name      String // "Working Hours", "Consulting Hours"
  timezone  String  @default("UTC") // IANA, e.g. "America/New_York"
  isDefault Boolean @default(false)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user       User                   @relation(fields: [userId], references: [id], onDelete: Restrict)
  slots      Availability[]
  overrides  AvailabilityOverride[]
  eventTypes EventType[]

  @@index([userId, isDeleted])
  @@index([userId, isDefault])
}

model Availability {
  id         String @id @default(uuid()) @db.Uuid
  scheduleId String @db.Uuid
  dayOfWeek  Int // 0=Sun, 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat
  startTime  String // "09:00" (24h, schedule's timezone)
  endTime    String // "17:00"

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedule AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId, dayOfWeek, isDeleted])
}

model AvailabilityOverride {
  id         String   @id @default(uuid()) @db.Uuid
  scheduleId String   @db.Uuid
  // NOTE: date comparisons in the slot engine must use the schedule's
  // timezone, not UTC, to avoid off-by-one errors at midnight.
  date       DateTime @db.Date
  isBlocked  Boolean  @default(true)

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedule AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, date])
  @@index([scheduleId])
}

model Booking {
  id          String  @id @default(uuid()) @db.Uuid
  eventTypeId String  @db.Uuid
  userId      String  @db.Uuid // the host
  meetingId   String? @unique @db.Uuid // created Meeting

  // Guest info — encrypted under the host user's DEK (Phase 5)
  guestName      Bytes // Encrypted guest name (AES-256-GCM)
  guestEmail     Bytes // Encrypted guest email (AES-256-GCM)
  guestNote      Bytes? // Encrypted guest note (AES-256-GCM)
  guestEmailBidx Bytes? // HMAC-SHA256 blind index — exact-match on encrypted guestEmail

  // Time
  startTime DateTime
  endTime   DateTime
  timezone  String // guest's timezone at time of booking

  status BookingStatus @default(PENDING)

  // Google Calendar
  googleEventId String?

  cancelReason String?
  canceledAt   DateTime?

  // Teams (Phase 6) — null = personal booking
  teamId String? @db.Uuid

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // EventType is soft-deleted in practice; Restrict is safe and documents intent
  eventType EventType @relation(fields: [eventTypeId], references: [id], onDelete: Restrict)
  // User must not be hard-deletable while bookings exist (guest record kept for audit)
  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  meeting   Meeting?  @relation(fields: [meetingId], references: [id])
  team      Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventTypeId])
  @@index([guestEmailBidx])
  @@index([startTime])
  @@index([status, isDeleted])
  @@index([userId, isDeleted]) // dashboard booking list query
  @@index([startTime, isDeleted]) // slot engine conflict check
  @@index([teamId, isDeleted])
}

// ================================
// BILLING (Phase 4)
// ================================

model UserUsage {
  id     String @id @default(uuid()) @db.Uuid
  // Phase 6 P5.8 — `@unique` dropped; replaced by two partial unique indexes
  // (added in raw SQL by the migration):
  //   UserUsage_user_personal_unique: (userId) WHERE teamId IS NULL
  //   UserUsage_user_team_unique:     (userId, teamId) WHERE teamId IS NOT NULL
  // Each user now has one row per scope they consume against: their personal
  // row (teamId null) plus one row per team they own (teamId set).
  userId String @db.Uuid

  // Usage counters — reset monthly by cron job
  transcriptionMinutesUsed Int   @default(0)
  recallHoursUsed          Float @default(0)
  aiCreditsUsed            Int   @default(0)
  storageGbUsed            Float @default(0)

  // Period tracking
  periodStart DateTime @default(now())
  resetAt     DateTime // set to first day of next month on creation + after each reset

  // Teams (Phase 6) — attribution column for per-team breakdown.
  // null = consumption against the payer's personal pool.
  teamId String? @db.Uuid

  updatedAt DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, teamId]) // composite for scoped lookups (Phase 6 P5.8)
  @@index([resetAt]) // cron job queries by resetAt to find users to reset
  @@index([teamId])
}

model Subscription {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid

  // Razorpay identifiers
  razorpayCustomerId     String  @unique
  razorpaySubscriptionId String? @unique

  // Plan state
  plan             Plan      @default(FREE)
  status           String    @default("active") // Razorpay subscription status: created | authenticated | active | pending | halted | cancelled | completed | expired
  currentPeriodEnd DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([razorpayCustomerId])
  @@index([plan])
}

// ================================
// TEAMS (Phase 6)
// ================================

// Key/value store for admin-tunable platform limits.
// Seeded with: max_teams_per_pro_user=3, max_teams_per_business_user=10,
// max_members_per_team=50, team_invite_expiry_days=7.
model SystemConfig {
  key       String   @id
  value     String
  updatedBy String?  @db.Uuid // AdminUser.id — audit field, no FK for loose coupling
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Team {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique
  description String?
  ownerId     String    @db.Uuid
  logoUrl     String?

  // Per-team DEK (Phase 6 P3 — additive to Phase 5's per-user DEK).
  // Always populated inside the createTeam() transaction; never null in practice.
  wrappedDek Bytes
  dekVersion Int    @default(1)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  inviteLinkToken     String?   @unique
  inviteLinkEnabled   Boolean   @default(false)
  inviteLinkExpiresAt DateTime?

  owner      User             @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members    TeamMember[]
  invites    TeamInvite[]
  dekHistory TeamDekHistory[]
  meetings   Meeting[]
  cards      Card[]
  tasks      Task[]
  eventTypes EventType[]
  bookings   Booking[]
  tags       Tag[]
  usage      UserUsage[]

  @@index([ownerId, isDeleted])
}

model TeamMember {
  id        String    @id @default(uuid()) @db.Uuid
  teamId    String    @db.Uuid
  userId    String    @db.Uuid
  role      TeamRole  @default(MEMBER)
  joinedAt  DateTime  @default(now())
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  updatedAt DateTime  @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId]) // re-join flips isDeleted instead of inserting a new row
  @@index([userId, isDeleted])
  @@index([teamId, isDeleted])
  @@index([teamId, role, isDeleted])
}

// Active-invite uniqueness is enforced by a partial unique index added in
// the migration SQL (Prisma cannot model partial unique indexes natively):
//   CREATE UNIQUE INDEX team_invite_active_uniq
//     ON "TeamInvite" ("teamId", "email")
//     WHERE "isDeleted" = false
//       AND "acceptedAt" IS NULL
//       AND "declinedAt" IS NULL
//       AND "cancelledAt" IS NULL;
model TeamInvite {
  id          String    @id @default(uuid()) @db.Uuid
  teamId      String    @db.Uuid
  email       String // plaintext: looked up server-side without per-user DEK; logger redacts
  userId      String?   @db.Uuid // set if invitee already has an account
  role        TeamRole
  token       String    @unique
  invitedById String    @db.Uuid
  expiresAt   DateTime
  acceptedAt  DateTime?
  declinedAt  DateTime?
  cancelledAt DateTime?
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  team      Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy User  @relation("TeamInviteSender", fields: [invitedById], references: [id], onDelete: Restrict)
  user      User? @relation("TeamInviteRecipient", fields: [userId], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([email, isDeleted])
  @@index([teamId, isDeleted])
  @@index([userId])
}

// Append-only on rotation. Hard cascade on Team delete = crypto-shred for the team's data.
model TeamDekHistory {
  id         String   @id @default(uuid()) @db.Uuid
  teamId     String   @db.Uuid
  version    Int
  wrappedDek Bytes
  createdAt  DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, version])
  @@index([teamId])
}

