{
  "name": "calendar-backend",
  "version": "1.0.0",
  "description": "Calendar + Smart Meeting Assistant Backend",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "prisma generate",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "admin:seed": "tsx src/scripts/seedAdmin.ts",
    "lint": "eslint .",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": "prettier --write"
  },
  "keywords": [
    "calendar",
    "meetings",
    "transcription",
    "ai",
    "scheduling"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@deepgram/sdk": "^4.11.3",
    "@google-cloud/storage": "^7.18.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.0",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "googleapis": "^148.0.0",
    "helmet": "^8.1.0",
    "ical.js": "^2.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.2",
    "nanoid": "^5.1.6",
    "node-cache": "^5.1.2",
    "pdfkit": "^0.17.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.19.0",
    "qrcode": "^1.5.4",
    "redis": "^5.12.1",
    "resend": "^6.10.0",
    "rrule": "^2.8.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.3",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.30.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.2.0",
    "lint-staged": "^17.0.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
